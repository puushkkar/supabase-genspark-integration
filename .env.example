# Supabase Configuration
# Copy this file to .env and fill in your values

# Your Supabase project URL
SUPABASE_PROJECT_URL=https://your-project-id.supabase.co

# Your Supabase publishable API key (safe to share)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx

# Your Supabase secret API key (KEEP PRIVATE - do not share or commit)
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Table name to connect
SUPABASE_TABLE_NAME=users

# GenSpark AI Sheets
GENSPARK_PROJECT_URL=https://www.genspark.ai/agents?type=sheets_agent_new

# REST API Endpoint (constructed from above values)
REST_API_ENDPOINT=${SUPABASE_PROJECT_URL}/rest/v1/${SUPABASE_TABLE_NAME}?apikey=${SUPABASE_PUBLISHABLE_KEY}

# Development
NODE_ENV=development

# CORS Settings
CORS_ALLOWED_ORIGINS=*

# Optional: Enable debug logging
DEBUG=false

# Optional: Rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
